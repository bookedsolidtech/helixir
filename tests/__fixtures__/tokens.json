{
  "$schema": "https://tr.designtokens.org/format/",
  "color": {
    "$type": "color",
    "primary": {
      "100": {
        "$value": "#dce8ff",
        "$description": "Lightest tint of the primary brand color, suitable for backgrounds."
      },
      "200": {
        "$value": "#aac4ff",
        "$description": "Light tint of primary, used for hover states on light backgrounds."
      },
      "300": {
        "$value": "#6694ff",
        "$description": "Mid-range primary tint, used for secondary interactive elements."
      },
      "400": {
        "$value": "#3366ff",
        "$description": "Core primary brand color."
      },
      "500": {
        "$value": "#1a4ddb",
        "$description": "Darker primary, used for pressed/active states."
      },
      "600": {
        "$value": "#0d35a8",
        "$description": "Darkest primary shade for high-contrast text on light backgrounds."
      }
    },
    "neutral": {
      "$type": "color",
      "0": {
        "$value": "#ffffff",
        "$description": "Pure white."
      },
      "100": {
        "$value": "#f5f5f5",
        "$description": "Near-white surface color."
      },
      "200": {
        "$value": "#e0e0e0",
        "$description": "Subtle divider and border color."
      },
      "300": {
        "$value": "#bdbdbd",
        "$description": "Secondary border and disabled element color."
      },
      "400": {
        "$value": "#9e9e9e",
        "$description": "Secondary text and placeholder color."
      },
      "500": {
        "$value": "#757575",
        "$description": "Body text on light backgrounds."
      },
      "600": {
        "$value": "#424242",
        "$description": "Strong text on light backgrounds."
      },
      "700": {
        "$value": "#212121",
        "$description": "Near-black, used for headings."
      },
      "1000": {
        "$value": "#000000",
        "$description": "Pure black."
      }
    },
    "semantic": {
      "$type": "color",
      "success": {
        "$value": "#2e7d32",
        "$description": "Indicates a successful state or confirmation."
      },
      "warning": {
        "$value": "#e65100",
        "$description": "Indicates a cautionary or warning state."
      },
      "error": {
        "$value": "#c62828",
        "$description": "Indicates an error or destructive state."
      },
      "info": {
        "$value": "#0277bd",
        "$description": "Indicates an informational state."
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "0": {
      "$value": "0px",
      "$description": "Zero spacing, used to explicitly remove gaps."
    },
    "1": {
      "$value": "4px",
      "$description": "Extra-small spacing unit (1x base)."
    },
    "2": {
      "$value": "8px",
      "$description": "Small spacing unit (2x base)."
    },
    "3": {
      "$value": "12px",
      "$description": "Small-medium spacing (3x base)."
    },
    "4": {
      "$value": "16px",
      "$description": "Base spacing unit. Used for standard component padding."
    },
    "5": {
      "$value": "20px",
      "$description": "Medium spacing unit."
    },
    "6": {
      "$value": "24px",
      "$description": "Large-medium spacing, commonly used for section gaps."
    },
    "8": {
      "$value": "32px",
      "$description": "Large spacing unit."
    },
    "10": {
      "$value": "40px",
      "$description": "Extra-large spacing unit."
    },
    "12": {
      "$value": "48px",
      "$description": "Section-level vertical spacing."
    },
    "16": {
      "$value": "64px"
    },
    "24": {
      "$value": "96px"
    }
  },
  "typography": {
    "fontFamily": {
      "$type": "fontFamily",
      "sans": {
        "$value": ["Inter", "system-ui", "-apple-system", "sans-serif"],
        "$description": "Primary sans-serif font stack for body and UI text."
      },
      "mono": {
        "$value": ["JetBrains Mono", "Fira Code", "monospace"],
        "$description": "Monospace font stack for code snippets and technical content."
      },
      "serif": {
        "$value": ["Georgia", "Times New Roman", "serif"],
        "$description": "Serif font stack for editorial or long-form content."
      }
    },
    "fontSize": {
      "$type": "dimension",
      "xs": {
        "$value": "11px",
        "$description": "Extra-small text, used for captions and helper text."
      },
      "sm": {
        "$value": "13px",
        "$description": "Small text, used for secondary labels."
      },
      "md": {
        "$value": "16px",
        "$description": "Base body font size."
      },
      "lg": {
        "$value": "18px",
        "$description": "Large body text."
      },
      "xl": {
        "$value": "20px",
        "$description": "Extra-large text, used for sub-headings."
      },
      "2xl": {
        "$value": "24px",
        "$description": "Section headings."
      },
      "3xl": {
        "$value": "30px",
        "$description": "Large headings."
      },
      "4xl": {
        "$value": "36px",
        "$description": "Display-level headings."
      }
    },
    "fontWeight": {
      "$type": "number",
      "regular": {
        "$value": 400,
        "$description": "Regular weight for body text."
      },
      "medium": {
        "$value": 500,
        "$description": "Medium weight for emphasized UI labels."
      },
      "semibold": {
        "$value": 600,
        "$description": "Semi-bold for sub-headings and button labels."
      },
      "bold": {
        "$value": 700,
        "$description": "Bold weight for headings."
      }
    },
    "lineHeight": {
      "$type": "number",
      "tight": {
        "$value": 1.25,
        "$description": "Tight line height, used for headings."
      },
      "normal": {
        "$value": 1.5,
        "$description": "Standard line height for body text."
      },
      "relaxed": {
        "$value": 1.75,
        "$description": "Relaxed line height for long-form prose."
      }
    },
    "letterSpacing": {
      "$type": "dimension",
      "tight": {
        "$value": "-0.5px",
        "$description": "Negative tracking for large display headings."
      },
      "normal": {
        "$value": "0px",
        "$description": "Default letter spacing."
      },
      "wide": {
        "$value": "0.5px",
        "$description": "Wide tracking for all-caps labels and badges."
      }
    }
  }
}
