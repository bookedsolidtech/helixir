#!/bin/sh

# ── Quality Gate: pre-push ──────────────────────────────────────────────
# Runs pnpm run preflight which executes all 6 gates:
#   1. Lint  2. Format  3. Type-check  4. Build  5. Test  6. Docker CI
#
# Gate 6 (Docker CI) runs if act + Docker are available.
# Skip with: SKIP_ACT=1 git push
# Emergency bypass: git push --no-verify
# ─────────────────────────────────────────────────────────────────────────

pnpm run preflight

if [ $? -ne 0 ]; then
  echo ""
  echo "=== PUSH BLOCKED ==="
  echo "Preflight failed. Fix errors and retry."
  exit 1
fi
