              "attribute": "validated",
              "reflects": true
            },
            {
              "kind": "field",
              "name": "placeholder",
              "type": { "text": "string" },
              "default": "''",
              "description": "Placeholder text.",
              "attribute": "placeholder"
            }
          ],
          "events": [
            {
              "name": "change",
              "type": { "text": "Event" },
              "description": "Fired when value changes."
            },
            {
              "name": "input",
              "type": { "text": "Event" },
              "description": "Fired on each keystroke."
            }
