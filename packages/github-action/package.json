{
  "name": "@helixir/github-action",
  "version": "0.1.0",
  "private": true,
  "description": "GitHub Action that runs helixir CLI in PR workflows for web component quality gates",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "github-action",
    "web-components",
    "helixir",
    "quality-gates"
  ],
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
