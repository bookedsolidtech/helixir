{
  "schemaVersion": "1.0.0",
  "readme": "https://patternfly.org",
  "modules": [
    {
      "kind": "javascript-module",
      "path": "src/components/button/pf-button.js",
      "declarations": [
        {
          "kind": "class",
          "description": "PatternFly button component.",
          "name": "PfButton",
          "tagName": "pf-button",
          "members": [
            {
              "kind": "field",
              "name": "variant",
              "type": {
                "text": "'primary' | 'secondary' | 'tertiary' | 'danger' | 'warning' | 'link' | 'plain' | 'control'"
              },
              "default": "'primary'",
              "description": "The button variant.",
              "attribute": "variant",
              "reflects": true
            },
            {
              "kind": "field",
              "name": "disabled",
              "type": { "text": "boolean" },
              "default": "false",
              "description": "Disables the button.",
              "attribute": "disabled",
              "reflects": true
            },
            {
              "kind": "field",
              "name": "loading",
              "type": { "text": "boolean" },
              "default": "false",
              "description": "Shows a loading indicator.",
              "attribute": "loading",
              "reflects": true
            },
            {
              "kind": "field",
              "name": "plain",
              "type": { "text": "boolean" },
              "default": "false",
              "description": "Renders the button as plain.",
              "attribute": "plain",
              "reflects": true
            },
            {
              "kind": "field",
              "name": "block",
              "type": { "text": "boolean" },
              "default": "false",
              "description": "Renders the button as a block-level element.",
              "attribute": "block",
              "reflects": true
            }
          ],
          "events": [
            {
              "name": "click",
              "type": { "text": "MouseEvent" },
              "description": "Fired when the button is clicked."
            }
          ],
          "slots": [
            { "name": "", "description": "Default slot — button label." },
            { "name": "icon", "description": "Icon slot." }
          ],
          "cssProperties": [
            {
              "name": "--pf-c-button--m-primary--BackgroundColor",
              "description": "Background color for primary variant."
            }
          ]
        }
      ]
    },
    {
