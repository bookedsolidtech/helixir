          "slots": [
            { "name": "", "description": "Default slot — modal body content." },
            { "name": "header", "description": "Modal header slot." },
            { "name": "footer", "description": "Modal footer slot." },
            { "name": "description", "description": "Modal description slot." }
          ]
        }
      ]
    },
